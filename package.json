{
  "name": "@medixdeck/ui",
  "version": "0.1.4",
  "description": "MedixDeck shared UI component library — built with Chakra UI v3 and Vite",
  "author": "MedixDeck Team",
  "license": "MIT",
  "private": false,
  "type": "module",
  "homepage": "https://github.com/medixdeck/medixdeck-ui#readme",
  "bugs": {
    "url": "https://github.com/medixdeck/medixdeck-ui/issues"
  },
  "engines": {
    "node": ">=18",
    "npm": ">=9"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.build.json && vite build",
    "build:app": "vite build -c vite.app.config.ts",
    "build:watch": "vite build --watch",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint lib --ext .ts,.tsx",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "npm run build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@chakra-ui/react": ">=3.0.0",
    "framer-motion": ">=11.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "framer-motion": {
      "optional": true
    }
  },
  "devDependencies": {
    "@chakra-ui/react": "^3.21.0",
    "@emotion/react": "^11.13.0",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-links": "^8.6.18",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@testing-library/react": "^16.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/testing-library__jest-dom": "^5.14.9",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^9.25.1",
    "globals": "^16.0.0",
    "jsdom": "^29.0.2",
    "storybook": "^8.6.18",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "framer-motion": ">=11.0.0",
    "next-themes": "^0.4.4"
  },
  "keywords": [
    "medixdeck",
    "ui",
    "components",
    "design-system",
    "chakra-ui",
    "react",
    "healthcare"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/medixdeck/medixdeck-ui.git"
  },
  "publishConfig": {
    "access": "public"
  }
}