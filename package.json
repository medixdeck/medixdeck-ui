{
  "name": "@medixdeck/ui",
  "version": "0.1.0",
  "description": "MedixDeck shared UI component library — built with Chakra UI v3 and Vite",
  "author": "MedixDeck Team",
  "license": "MIT",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.build.json && vite build",
    "build:app": "vite build -c vite.app.config.ts",
    "build:watch": "vite build --watch",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint lib --ext .ts,.tsx",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@chakra-ui/react": ">=3.0.0",
    "framer-motion": ">=11.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "framer-motion": { "optional": true }
  },
  "devDependencies": {
    "@chakra-ui/react": "^3.21.0",
    "@emotion/react": "^11.13.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.3.0"
  },
  "dependencies": {
    "framer-motion": "^12.38.0",
    "next-themes": "^0.4.4"
  },
  "keywords": [
    "medixdeck",
    "ui",
    "components",
    "design-system",
    "chakra-ui",
    "react",
    "healthcare"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/medixdeck/medixdeck-ui.git"
  }
}
